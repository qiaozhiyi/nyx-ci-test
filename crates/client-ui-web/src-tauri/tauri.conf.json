{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nyx Operator",
  "version": "0.1.0",
  "identifier": "nyx.operator-ui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Nyx Operator",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
